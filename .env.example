# Firebase Client Config (Exposed to Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Email Configuration (Private - Server Side)
# Use an App Password if using Gmail
EMAIL_USER=
EMAIL_PASS=

# Firebase Admin Configuration (Private - Server Side)
# Should be a JSON string of your service account key
FIREBASE_SERVICE_ACCOUNT=
