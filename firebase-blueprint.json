{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and message limits",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "dailyMessageCount": { "type": "integer" },
        "lastMessageDate": { "type": "string", "format": "date" },
        "extraMessageLimit": { "type": "integer" }
      },
      "required": ["uid", "dailyMessageCount", "lastMessageDate"]
    },
    "MessageRequest": {
      "title": "MessageRequest",
      "description": "Request for extra messages",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "requestedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["userId", "requestedAt", "status"]
    },
    "PrivateChat": {
      "title": "PrivateChat",
      "description": "1-to-1 conversation",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "blockedBy": { "type": "string" }
      },
      "required": ["participants"]
    },
    "Question": {
      "title": "Question",
      "description": "NEET Question saved in Mistake Vault",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "integer" },
        "explanation": { "type": "string" },
        "subject": { "type": "string" },
        "chapter": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "text", "options", "correctAnswer", "subject", "chapter"]
    },
    "Duel": {
      "title": "Duel",
      "description": "Real-time multiplayer battle session",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["waiting", "active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "questions": { "type": "array", "items": { "$ref": "Question" } },
        "players": { "type": "object" },
        "winner": { "type": "string" }
      },
      "required": ["status", "createdAt", "questions", "players"]
    },
    "ChatArchive": {
      "title": "ChatArchive",
      "description": "Deleted chat messages for admin review",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" }
      },
      "required": ["userId", "timestamp"]
    },
    "StudyMaterial": {
      "title": "StudyMaterial",
      "description": "PDF notes uploaded by admin",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "type": { "type": "string" },
        "url": { "type": "string" },
        "fileName": { "type": "string" },
        "size": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "subject", "type", "url"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile with daily message metrics."
    },
    "/users/{userId}/mistakes/{mistakeId}": {
      "schema": "Question",
      "description": "Incorrect questions stored for review."
    },
    "/message_requests/{requestId}": {
      "schema": "MessageRequest",
      "description": "Requests for extra messaging capacity."
    },
    "/private_chats/{chatId}": {
      "schema": "PrivateChat",
      "description": "1-to-1 conversation messages."
    },
    "/duels/{duelId}": {
      "schema": "Duel",
      "description": "Live head-to-head quiz sessions."
    },
    "/chat_archives/{archiveId}": {
      "schema": "ChatArchive",
      "description": "Backup of deleted chat messages for moderation."
    },
    "/study_materials/{materialId}": {
      "schema": "StudyMaterial",
      "description": "Central repository for PDFs/Notes."
    }
  }
}
