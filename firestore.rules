rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); } // Keeping it loose for now but ready for email_verified
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email == 'divakarkumarmob@gmail.com'; 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128; 
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['isOnline', 'lastSeen']) &&
             data.isOnline is bool &&
             data.lastSeen is string &&
             data.lastSeen.size() <= 64;
    }

    function isPresenceUpdate() {
      return incoming().diff(existing()).affectedKeys().hasOnly(['isOnline', 'activeChatId', 'lastSeen']);
    }

    // --- Debug/Connection Test ---
    match /test/connection {
      allow read: if true; 
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Identity Protection: Valid ID needed
      allow get: if isSignedIn() && isValidId(userId);
      
      // Admin only can scrape user list
      allow list: if isAdmin();
      
      // Profiles
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      // Tiered Identity Logic for Updates
      allow update: if isOwner(userId) && (
        // Action: Presence Sync (Fast Path)
        isPresenceUpdate() ||
        // Action: Profile Update (Stats, Streak)
        incoming().diff(existing()).affectedKeys().hasAny(['streak', 'lastLoginDate', 'dailyMessageCount', 'lastMessageDate']) ||
        // Action: Moderation alerts (Semi-automated)
        incoming().diff(existing()).affectedKeys().hasOnly(['nameChangeHistory', 'moderation'])
      ) || isAdmin();

      // Sub-collections: strictly inherited owner access
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Community Chat ---
    match /community_chat/{messageId} {
      // Secure List Query: Must check senderId visibility or just be signed in for this public feed
      allow list: if isSignedIn() && resource.data.senderId is string;
      allow get: if isSignedIn();
      
      allow create: if isSignedIn() && 
                    incoming().senderId == request.auth.uid &&
                    incoming().text is string && incoming().text.size() <= 2000;
                    
      allow update: if isSignedIn() && (
        (existing().senderId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'edited'])) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (existing().senderId == request.auth.uid || isAdmin());
    }

    // --- Private Chats ---
    match /private_chats/{chatId} {
      function isParticipant() { return request.auth.uid in existing().participants; }
      function isInitialParticipant() { return request.auth.uid in incoming().participants; }

      allow read: if isSignedIn() && isParticipant();
      allow create: if isSignedIn() && isInitialParticipant();
      allow update: if isSignedIn() && (isParticipant() || isAdmin());
      
      match /messages/{messageId} {
        function getParticipants() { return get(/databases/$(database)/documents/private_chats/$(chatId)).data.participants; }

        allow read: if isSignedIn() && (request.auth.uid in getParticipants());
        
        allow create: if isSignedIn() && 
                      (request.auth.uid in getParticipants()) &&
                      incoming().senderId == request.auth.uid;
        
        allow update: if isSignedIn() && (
           // Action: Mark Seen
           (existing().senderId != request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
           // Action: Edit/Soft Delete
           (existing().senderId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'edited', 'deletedFor']))
        );
        allow delete: if isSignedIn() && (existing().senderId == request.auth.uid || isAdmin());
      }
    }

    // --- Leaderboard ---
    match /leaderboard/{userId} {
      // Secure List Query: evaluates resource.data
      allow list: if isSignedIn() && resource.data.points >= 0;
      allow get: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // --- Utility Collections ---
    match /friend_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.toId == request.auth.uid || resource.data.fromId == request.auth.uid);
      allow create: if isSignedIn() && incoming().fromId == request.auth.uid;
      allow update: if isSignedIn() && (
        (existing().toId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        (existing().fromId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['senderSeen']))
      );
      allow delete: if isSignedIn() && (existing().toId == request.auth.uid || existing().fromId == request.auth.uid || isAdmin());
    }

    match /duels/{duelId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        (existing().status == 'waiting' && !(request.auth.uid in existing().players) && incoming().status == 'active') ||
        (request.auth.uid in existing().players.keys())
      );
    }

    match /name_alerts/{alertId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid);
    }
  }
}
