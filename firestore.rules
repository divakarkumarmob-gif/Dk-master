rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); } // Keeping it loose for now but ready for email_verified
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'divakarkumarmob@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128; 
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['isOnline', 'lastActive']) &&
             data.isOnline is bool &&
             data.lastActive is string &&
             data.lastActive.size() <= 128;
    }

    function isPresenceUpdate() {
      return incoming().diff(existing()).affectedKeys().hasOnly(['isOnline', 'activeChatId', 'lastActive']);
    }

    // --- Debug/Connection Test ---
    match /test/connection {
      allow read: if true; 
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn();
      
      // Profiles
      allow create: if isOwner(userId);
      
      allow update: if isOwner(userId) && (
        // Action: Presence Sync (Fast Path)
        incoming().diff(existing()).affectedKeys().hasAny(['isOnline', 'lastActive', 'activeChatId']) ||
        // Action: Profile Update (Stats, Streak, Connections, Username)
        incoming().diff(existing()).affectedKeys().hasAny(['streak', 'lastLoginDate', 'dailyMessageCount', 'lastMessageDate', 'connections', 'username']) ||
        // Action: Moderation alerts (Semi-automated)
        incoming().diff(existing()).affectedKeys().hasOnly(['nameChangeHistory', 'moderation'])
      ) || isAdmin();

      // Sub-collections: owner or admin access
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --- Community Chat ---
    match /community_chat/{messageId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      
      allow create: if isSignedIn() && 
                    incoming().userId == request.auth.uid &&
                    incoming().text is string && incoming().text.size() <= 2000;
                    
      allow update: if isSignedIn() && (
        (existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasAny(['text', 'isEdited', 'isDeleted'])) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // --- Message Requests (Admin Only) ---
    match /message_requests/{reqId} {
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // --- Chat Archives (System/Admin) ---
    match /chat_archives/{archiveId} {
      allow list, get: if isAdmin();
      allow create: if isSignedIn(); // Allow user to archive their own deletions
      allow update, delete: if isAdmin();
    }

    // --- Private Chats ---
    match /private_chats/{chatId} {
      function isParticipant() { return request.auth.uid in existing().participants; }
      function isInitialParticipant() { return request.auth.uid in incoming().participants; }

      allow read: if isSignedIn() && isParticipant();
      allow create: if isSignedIn() && isInitialParticipant();
      allow update: if isSignedIn() && (isParticipant() || isAdmin());
      
      match /messages/{messageId} {
        function getParticipants() { return get(/databases/$(database)/documents/private_chats/$(chatId)).data.participants; }

        allow read: if isSignedIn() && (request.auth.uid in getParticipants());
        
        allow create: if isSignedIn() && 
                      (request.auth.uid in getParticipants()) &&
                      incoming().userId == request.auth.uid;
        
        allow update: if isSignedIn() && (
           // Action: Mark Status
           (request.auth.uid in getParticipants() && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
           // Action: Edit/Soft Delete
           (existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasAny(['text', 'isEdited', 'isDeleted'])) ||
           isAdmin()
        );
        allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      }
    }

    // --- Leaderboard ---
    match /leaderboard/{userId} {
      // Secure List Query
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // --- Utility Collections ---
    match /friend_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.to == request.auth.uid || resource.data.from == request.auth.uid);
      allow create: if isSignedIn() && incoming().from == request.auth.uid;
      allow update: if isSignedIn() && (
        (existing().to == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (existing().to == request.auth.uid || existing().from == request.auth.uid || isAdmin());
    }

    match /study_materials/{materialId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /duels/{duelId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        (existing().status == 'waiting' && !(request.auth.uid in existing().players) && incoming().status == 'active') ||
        (request.auth.uid in existing().players.keys())
      );
    }

    match /name_alerts/{alertId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid);
    }

    match /admin_alerts/{alertId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}
